  last_synced_at     DateTime?

  @@index([customer])
  @@map("setup_intents")
  @@schema("stripe")
}

model StripePaymentMethod {
  id              String   @id
  object          String?
  created         Int?
  customer        String?
  type            String?
  billing_details Json?
  metadata        Json?
  card            Json?
  last_synced_at  DateTime?

  @@index([customer])
  @@map("payment_methods")
  @@schema("stripe")
}

model StripePaymentIntent {
