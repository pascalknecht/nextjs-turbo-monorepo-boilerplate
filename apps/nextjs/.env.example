# Copy to `.env` in this directory (apps/nextjs/.env). Do not commit `.env`.

# ── Database ────────────────────────────────────────────
# Local: Postgres on your machine. Docker dev: compose overrides DATABASE_URL for the nextjs service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextjs-boilerplate

# ── App URLs ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Better Auth ─────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# ── Google OAuth (optional) ─────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Stripe (optional) ───────────────────────────────────
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_KEY=pk_test_...

# ── Misc ────────────────────────────────────────────────
# Set to "1" to skip env validation (e.g., during Docker builds)
# SKIP_ENV_VALIDATION=1
